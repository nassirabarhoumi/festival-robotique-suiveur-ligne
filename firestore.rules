rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Équipes du classement.
    // - Lecture PUBLIQUE : tout le monde peut voir le classement / l'écran d'affichage.
    // - Écriture RÉSERVÉE aux arbitres connectés (Firebase Auth email/mot de passe).
    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
